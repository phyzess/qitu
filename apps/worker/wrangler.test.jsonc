{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qitu-worker-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "APP_ENV": "local",
    "EMAIL_DELIVERY_MODE": "store",
    "PUBLIC_APP_NAME": "qitu",
    "PUBLIC_APP_URL": "http://localhost:5173",
    "MAIL_FROM": "noreply@example.com",
    "MAIL_REPLY_TO": "",
  },
  "send_email": [
    {
      "name": "EMAIL",
      "remote": false,
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "qitu-test",
      "database_id": "00000000-0000-0000-0000-000000000000",
    },
  ],
  "r2_buckets": [
    {
      "binding": "SOURCE_FILES",
      "bucket_name": "qitu-source-files-test",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "IMPORT_JOBS",
        "queue": "qitu-import-jobs-test",
      },
    ],
    "consumers": [
      {
        "queue": "qitu-import-jobs-test",
        "max_batch_size": 10,
        "max_batch_timeout": 1,
        "max_retries": 3,
        "dead_letter_queue": "qitu-import-jobs-test-dlq",
      },
    ],
  },
}
